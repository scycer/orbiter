{
  "name": "orchestrator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names api,ui --prefix-colors blue,green \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173 --host 0.0.0.0",
    "dev:ui": "vite",
    "dev:api": "tsx watch server/index.ts",
    "start": "tsx server/index.ts & vite preview --port 5173 --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@tanstack/react-query": "^5.95.2",
    "cmdk": "^1.1.1",
    "hono": "^4.12.9",
    "lucide-react": "^1.6.0",
    "react-router-dom": "^7.13.2",
    "sonner": "^2.0.7"
  }
}

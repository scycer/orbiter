#!/bin/bash
# Dockerized doctl wrapper — no native install needed
# Sources .env for DIGITALOCEAN_ACCESS_TOKEN if not already set

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# Source token from .env if not already exported
if [ -z "${DIGITALOCEAN_ACCESS_TOKEN:-}" ] && [ -f "$PROJECT_DIR/.env" ]; then
  DO_API_TOKEN=$(grep '^DO_API_TOKEN=' "$PROJECT_DIR/.env" | cut -d'=' -f2-)
  export DIGITALOCEAN_ACCESS_TOKEN="${DO_API_TOKEN}"
fi

if [ -z "${DIGITALOCEAN_ACCESS_TOKEN:-}" ]; then
  echo "ERROR: No DIGITALOCEAN_ACCESS_TOKEN set and no DO_API_TOKEN in .env" >&2
  exit 1
fi

exec docker run --rm \
  -e DIGITALOCEAN_ACCESS_TOKEN \
  -v "${HOME}/.ssh:/root/.ssh:ro" \
  digitalocean/doctl:latest "$@"
